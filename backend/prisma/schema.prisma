// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
// Int, String, DateTime, Float, Boolean
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model photos {
  id Int @id @default(autoincrement())
  title String
  description String?
  date DateTime
  url String

  location_id Int?
  location  locations? @relation(fields: [location_id], references: [id])

  photo_category_id Int
  category photo_categories @relation(fields: [photo_category_id], references: [id])

  photoEquipment photo_equipment[]
}

model photo_categories {
  id Int @id @default(autoincrement())
  name String @unique

  photos photos[]
}

model locations {
  id Int @id @default(autoincrement())
  name String @unique
  latitude Float
  longitude Float

  photos photos[]
}

model equipment {
  id Int @id @default(autoincrement())
  name String @unique

  equipment_category_id Int
  category equipment_categories @relation(fields: [equipment_category_id], references: [id])

  photoEquipment photo_equipment[]
}

model equipment_categories {
  id Int @id @default(autoincrement())
  name String @unique

  equipment equipment[]
}

model photo_equipment {
  photo_id Int
  equipment_id Int
  @@id([photo_id, equipment_id])

  photo      photos    @relation(fields: [photo_id], references: [id])
  equipment  equipment @relation(fields: [equipment_id], references: [id])
}